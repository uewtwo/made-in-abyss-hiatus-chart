{
  "compilerOptions": {
    "lib": [
      "dom",
      "DOM.Iterable",
      "esnext"
    ],
    "module": "ESNext",
    "allowJs": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@hiatus/*": [
        "./src/*"
      ]
    },
    "moduleResolution": "bundler",
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
